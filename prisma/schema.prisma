// Motor Auto Care CRM - Prisma Schema
// PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth & Roles ──────────────────────────────────────────────────────────

model Role {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]
}

model User {
  id            String       @id @default(uuid())
  clerkId       String       @unique
  email         String?
  name          String?
  roleId        String
  role          Role         @relation(fields: [roleId], references: [id])
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  notifications Notification[]
  activityLogs  ActivityLog[]
  branches      UserBranch[]

  @@index([email])
}

// ─── Branch ────────────────────────────────────────────────────────────────

model Branch {
  id           String       @id @default(uuid())
  name         String
  address      String?
  phone        String?
  email        String?
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  userBranches UserBranch[]
  jobCards     JobCard[]
  invoices     Invoice[]
  expenses     Expense[]
  appointments Appointment[]
  staff        Staff[]
  payments     Payment[]
  inventoryItems InventoryItem[]

  @@index([name])
  @@index([isActive])
}

model UserBranch {
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  branchId  String
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([userId, branchId])
  @@index([userId])
  @@index([branchId])
}

// ─── Customer & Vehicle ────────────────────────────────────────────────────

model Customer {
  id               String            @id @default(uuid())
  name             String
  phone            String
  address          String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  vehicles         Vehicle[]
  jobCards         JobCard[]
  invoices         Invoice[]
  feedback         Feedback[]
  appointments     Appointment[]
  serviceReminders ServiceReminder[]

  @@index([phone])
  @@index([name])
}

model Vehicle {
  id               String            @id @default(uuid())
  customerId       String
  customer         Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  numberPlate      String
  make             String?
  model            String?
  year             Int?
  vin              String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  jobCards         JobCard[]
  appointments     Appointment[]
  serviceReminders ServiceReminder[]

  @@index([numberPlate])
  @@index([customerId])
}

// ─── Services ──────────────────────────────────────────────────────────────

model Service {
  id              String           @id @default(uuid())
  name            String
  description     String?
  defaultPrice    Decimal          @db.Decimal(12, 2)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  jobCardServices JobCardService[]

  @@index([name])
}

// ─── Job Cards ─────────────────────────────────────────────────────────────

model JobCard {
  id                    String                 @id @default(uuid())
  branchId              String
  branch                Branch                 @relation(fields: [branchId], references: [id], onDelete: Restrict)
  vehicleId             String
  vehicle               Vehicle                @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  customerId            String
  customer              Customer               @relation(fields: [customerId], references: [id], onDelete: Cascade)
  technicianId          String?
  technician            Staff?                 @relation(fields: [technicianId], references: [id], onDelete: SetNull)
  status                JobCardStatus          @default(OPEN)
  estimatedCost         Decimal?               @db.Decimal(12, 2)
  notes                 String?                @db.Text
  serviceDueDate        DateTime?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  services              JobCardService[]
  parts                 JobCardPart[]
  invoice               Invoice?
  payments              Payment[]
  feedback              Feedback[]
  inventoryTransactions InventoryTransaction[]
  images                JobCardImage[]

  @@index([branchId])
  @@index([status])
  @@index([vehicleId])
  @@index([customerId])
  @@index([technicianId])
  @@index([createdAt])
}

enum JobCardStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CLOSED
}

model JobCardService {
  id        String   @id @default(uuid())
  jobCardId String
  jobCard   JobCard  @relation(fields: [jobCardId], references: [id], onDelete: Cascade)
  serviceId String
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  quantity  Int      @default(1)
  unitPrice Decimal  @db.Decimal(12, 2)
  completed Boolean  @default(false)
  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([jobCardId, serviceId])
  @@index([jobCardId])
}

model JobCardPart {
  id              String        @id @default(uuid())
  jobCardId       String
  jobCard         JobCard       @relation(fields: [jobCardId], references: [id], onDelete: Cascade)
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)
  quantity        Int
  unitPrice       Decimal       @db.Decimal(12, 2)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([jobCardId])
}

model JobCardImage {
  id        String   @id @default(uuid())
  jobCardId String
  jobCard   JobCard  @relation(fields: [jobCardId], references: [id], onDelete: Cascade)
  url       String
  createdAt DateTime @default(now())

  @@index([jobCardId])
}

// ─── Inventory ─────────────────────────────────────────────────────────────

model Supplier {
  id             String          @id @default(uuid())
  name           String
  contact        String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  inventoryItems InventoryItem[]
}

model InventoryItem {
  id            String                 @id @default(uuid())
  branchId      String
  branch        Branch                 @relation(fields: [branchId], references: [id], onDelete: Restrict)
  name          String
  sku           String?
  supplierId    String?
  supplier      Supplier?              @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  purchasePrice Decimal                @db.Decimal(12, 2)
  sellingPrice  Decimal                @db.Decimal(12, 2)
  quantity      Int                    @default(0)
  minQuantity   Int                    @default(0)
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  transactions  InventoryTransaction[]
  jobCardParts  JobCardPart[]

  @@unique([branchId, sku])
  @@index([branchId])
  @@index([name])
}

model InventoryTransaction {
  id              String                   @id @default(uuid())
  inventoryItemId String
  inventoryItem   InventoryItem            @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  quantity        Int
  type            InventoryTransactionType
  jobCardId       String?
  jobCard         JobCard?                 @relation(fields: [jobCardId], references: [id], onDelete: SetNull)
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  @@index([inventoryItemId])
  @@index([jobCardId])
}

enum InventoryTransactionType {
  PURCHASE
  SALE
  ADJUSTMENT
}

// ─── Expenses ──────────────────────────────────────────────────────────────

enum ExpenseCategory {
  RENT
  ELECTRICITY
  TOOLS
  SUPPLIES
  OTHER
}

model Expense {
  id          String          @id @default(uuid())
  branchId    String
  branch      Branch          @relation(fields: [branchId], references: [id], onDelete: Restrict)
  category    ExpenseCategory
  amount      Decimal         @db.Decimal(12, 2)
  date        DateTime
  description String?         @db.Text
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([branchId])
  @@index([date])
  @@index([category])
}

// ─── Staff ─────────────────────────────────────────────────────────────────

enum StaffRole {
  MECHANIC
  MANAGER
  ADMIN
  HELPER
}

model Staff {
  id        String        @id @default(uuid())
  branchId  String
  branch    Branch        @relation(fields: [branchId], references: [id], onDelete: Restrict)
  name      String
  role      StaffRole
  phone     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  jobCards  JobCard[]
  salaries  StaffSalary[]

  @@index([branchId])
  @@index([role])
}

model StaffSalary {
  id         String   @id @default(uuid())
  staffId    String
  staff      Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)
  month      DateTime
  baseSalary Decimal  @db.Decimal(12, 2)
  bonus      Decimal  @db.Decimal(12, 2) @default(0)
  deductions Decimal  @db.Decimal(12, 2) @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([staffId])
  @@index([month])
}

// ─── Appointments ──────────────────────────────────────────────────────────

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

model Appointment {
  id          String            @id @default(uuid())
  branchId    String
  branch      Branch            @relation(fields: [branchId], references: [id], onDelete: Restrict)
  customerId  String
  customer    Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  vehicleId   String?
  vehicle     Vehicle?          @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  scheduledAt DateTime
  status      AppointmentStatus @default(SCHEDULED)
  notes       String?           @db.Text
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([branchId])
  @@index([scheduledAt])
  @@index([customerId])
  @@index([status])
  @@index([vehicleId])
}

// ─── Invoices & Payments ───────────────────────────────────────────────────

enum InvoiceStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
  UPI
  BANK_TRANSFER
  OTHER
}

model Invoice {
  id            String        @id @default(uuid())
  branchId      String
  branch        Branch        @relation(fields: [branchId], references: [id], onDelete: Restrict)
  jobCardId     String?       @unique
  jobCard       JobCard?      @relation(fields: [jobCardId], references: [id], onDelete: SetNull)
  customerId    String
  customer      Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  invoiceNumber String        @unique
  subtotal      Decimal       @db.Decimal(12, 2)
  tax           Decimal       @db.Decimal(12, 2) @default(0)
  total         Decimal       @db.Decimal(12, 2)
  status        InvoiceStatus @default(PENDING)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  items         InvoiceItem[]
  payments      Payment[]

  @@index([branchId])
  @@index([invoiceNumber])
  @@index([customerId])
  @@index([status])
  @@index([createdAt])
}

model InvoiceItem {
  id          String          @id @default(uuid())
  invoiceId   String
  invoice     Invoice         @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  quantity    Int             @default(1)
  unitPrice   Decimal         @db.Decimal(12, 2)
  type        InvoiceItemType
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([invoiceId])
}

enum InvoiceItemType {
  SERVICE
  PART
}

model Payment {
  id        String        @id @default(uuid())
  branchId  String
  branch    Branch        @relation(fields: [branchId], references: [id], onDelete: Restrict)
  invoiceId String?
  invoice   Invoice?      @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  jobCardId String?
  jobCard   JobCard?      @relation(fields: [jobCardId], references: [id], onDelete: SetNull)
  amount    Decimal       @db.Decimal(12, 2)
  method    PaymentMethod @default(CASH)
  paidAt    DateTime      @default(now())
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([branchId])
  @@index([invoiceId])
  @@index([jobCardId])
  @@index([paidAt])
}

// ─── Feedback, Notifications, Logs ────────────────────────────────────────

model Feedback {
  id         String   @id @default(uuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  jobCardId  String?
  jobCard    JobCard? @relation(fields: [jobCardId], references: [id], onDelete: SetNull)
  rating     Int
  comment    String?  @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([customerId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String?  @db.Text
  read      Boolean  @default(false)
  type      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([read])
}

model ActivityLog {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action     String
  entityType String
  entityId   String
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([entityType])
  @@index([createdAt])
}

// ─── Service Reminders ─────────────────────────────────────────────────────

model ServiceReminder {
  id          String    @id @default(uuid())
  vehicleId   String
  vehicle     Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  customerId  String
  customer    Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  dueDate     DateTime
  serviceType String?
  sent        Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([dueDate])
  @@index([vehicleId])
  @@index([customerId])
}

// ─── AI & Settings ─────────────────────────────────────────────────────────

model AIInsight {
  id        String   @id @default(uuid())
  type      String
  content   String   @db.Text
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GarageSettings {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
