# ─── Clerk Authentication ─────────────────────────────────────────────────────
# Get these from https://dashboard.clerk.com → Your App → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_YOUR_KEY_HERE
CLERK_SECRET_KEY=sk_test_YOUR_KEY_HERE

# Where Clerk redirects after sign-in / sign-up / sign-out
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/pending-access
CLERK_SIGN_OUT_URL=/

# ─── Super Admin ──────────────────────────────────────────────────────────────
# The email address that always has permanent Admin access.
# This user is auto-provisioned in the DB on first login.
# All other users must be manually provisioned by an Admin via the Staff section.
SUPER_ADMIN_EMAIL=admin@yourdomain.com

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public

# ─── AI (OpenRouter) ──────────────────────────────────────────────────────────
# Get your key from https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-YOUR_KEY_HERE
